msgid "Si mbledhim, përdorim dhe mbrojmë të dhënat tuaja personale."
msgstr "Πώς συλλέγουμε, χρησιμοποιούμε και προστατεύουμε τα προσωπικά σας δεδομένα."

msgid "Përditësuar së fundmi:"
msgstr "Τελευταία ενημέρωση:"

msgid "Janar 2026"
msgstr "Ιανουάριος 2026"

msgid "Hyrje"
msgstr "Εισαγωγή"

msgid "ValorEstate është e përkushtuar në mbrojtjen e privatësisë dhe të dhënave personale të përdoruesve të saj. Kjo politikë privatësie përshkruan mënyrën se si mbledhim, përdorim dhe mbrojmë informacionin tuaj kur vizitoni faqen tonë të internetit dhe përdorni shërbimet tona."
msgstr "Η ValorEstate δεσμεύεται να προστατεύει το απόρρητο και τα προσωπικά δεδομένα των χρηστών της. Αυτή η πολιτική απορρήτου περιγράφει τον τρόπο με τον οποίο συλλέγουμε, χρησιμοποιούμε και προστατεύουμε τις πληροφορίες σας."

msgid "Të dhënat që mbledhim"
msgstr "Δεδομένα που Συλλέγουμε"

msgid "Mbledhim të dhënat e mëposhtme kur ndërveproni me faqen tonë:"
msgstr "Συλλέγουμε τα παρακάτω δεδομένα όταν αλληλεπιδράτε με τον ιστότοπό μας:"

msgid "Informacione personale si emër, mbiemër, numër telefoni ose adresë email-i — vetëm nëse i jepni vetë."
msgstr "Προσωπικές πληροφορίες όπως όνομα, επώνυμο, αριθμός τηλεφώνου ή email — μόνο αν τις παρέχετε εσείς."

msgid "Aktiviteti dhe veprimtaritë e përdoruesit gjatë vizitës në faqe."
msgstr "Δραστηριότητα και ενέργειες χρήστη κατά την επίσκεψη στον ιστότοπο."

msgid "Adresa IP dhe të dhëna teknike të pajisjes suaj."
msgstr "Διεύθυνση IP και τεχνικά δεδομένα της συσκευής σας."

msgid "Të dhëna nga cookies dhe teknologji të ngjashme për qëllime statistikore."
msgstr "Δεδομένα από cookies και παρόμοιες τεχνολογίες για στατιστικούς σκοπούς."

msgid "Cookies"
msgstr "Cookies"

msgid "Faqja jonë përdor cookies për të përmirësuar përvojën tuaj. Cookies janë skedarë të vegjël që ruhen në pajisjen tuaj dhe na ndihmojnë të kuptojmë si e përdorni faqen tonë. Mund të kontrolloni ose çaktivizoni cookies nga cilësimet e shfletuesit tuaj."
msgstr "Ο ιστότοπός μας χρησιμοποιεί cookies για τη βελτίωση της εμπειρίας σας. Μπορείτε να ελέγξετε ή να απενεργοποιήσετε τα cookies από τις ρυθμίσεις του προγράμματος περιήγησής σας."

msgid "Si i përdorim të dhënat"
msgstr "Πώς Χρησιμοποιούμε τα Δεδομένα"

msgid "ValorEstate kryen përpunimin e ligjshëm të të dhënave personale duke respektuar të drejtat dhe liritë themelore të individit. Të dhënat tuaja përdoren për:"
msgstr "Η ValorEstate επεξεργάζεται νόμιμα τα προσωπικά δεδομένα σεβόμενη τα θεμελιώδη δικαιώματα. Τα δεδομένα σας χρησιμοποιούνται για:"

msgid "Ofrimin e shërbimeve të kërkuara dhe komunikimin me ju."
msgstr "Παροχή ζητούμενων υπηρεσιών και επικοινωνία μαζί σας."

msgid "Përmirësimin e faqes dhe shërbimeve tona."
msgstr "Βελτίωση του ιστότοπου και των υπηρεσιών μας."

msgid "Qëllime statistikore dhe studimore të brendshme."
msgstr "Εσωτερικοί στατιστικοί και ερευνητικοί σκοποί."

msgid "Respektimin e detyrimeve ligjore."
msgstr "Συμμόρφωση με νομικές υποχρεώσεις."

msgid "Ndarja me palë të treta"
msgstr "Κοινοποίηση σε Τρίτους"

msgid "ValorEstate garanton mos-shpërndarjen e të dhënave tuaja personale tek palë të treta, me përjashtim të rasteve kur kjo kërkohet me ligj ose kur ju keni dhënë pëlqimin tuaj shprehimisht."
msgstr "Η ValorEstate εγγυάται τη μη διανομή των προσωπικών σας δεδομένων σε τρίτους, εκτός εάν απαιτείται από τον νόμο ή με ρητή συγκατάθεσή σας."

msgid "Të drejtat tuaja"
msgstr "Τα Δικαιώματά σας"

msgid "Çdo individ rezervon të drejtat e mëposhtme pa pagesë:"
msgstr "Κάθε άτομο διατηρεί τα ακόλουθα δικαιώματα δωρεάν:"

msgid "E drejta e aksesit — të dini çfarë të dhënash mbajmë për ju."
msgstr "Δικαίωμα πρόσβασης — να γνωρίζετε ποια δεδομένα τηρούμε."

msgid "E drejta e korrigjimit — të korrigjoni të dhëna të pasakta."
msgstr "Δικαίωμα διόρθωσης — να διορθώσετε ανακριβή δεδομένα."

msgid "E drejta e fshirjes — të kërkoni fshirjen e të dhënave tuaja."
msgstr "Δικαίωμα διαγραφής — να ζητήσετε διαγραφή των δεδομένων σας."

msgid "E drejta e kundërshtimit — të kundërshtoni përpunimin e të dhënave."
msgstr "Δικαίωμα εναντίωσης — να αντιταχθείτε στην επεξεργασία."

msgid "Për të ushtruar këto të drejta, dërgoni email tek:"
msgstr "Για να ασκήσετε αυτά τα δικαιώματα, στείλτε email στο:"

msgid "Siguria e të dhënave"
msgstr "Ασφάλεια Δεδομένων"

msgid "Marrim masa teknike dhe organizative të përshtatshme për të mbrojtur të dhënat tuaja personale nga aksesi i paautorizuar, ndryshimi, shpalosja ose shkatërrimi. Megjithatë, asnjë metodë transmetimi nëpërmjet internetit nuk është 100% e sigurt."
msgstr "Λαμβάνουμε κατάλληλα τεχνικά και οργανωτικά μέτρα για την προστασία των προσωπικών σας δεδομένων. Ωστόσο, καμία μέθοδος μετάδοσης μέσω διαδικτύου δεν είναι 100% ασφαλής."

msgid "Ndryshimet e politikës"
msgstr "Αλλαγές Πολιτικής"

msgid "ValorEstate rezervon të drejtën e modifikimit dhe përditësimit të kësaj politike në çdo moment, në përputhje me legjislacionin në fuqi. Ndryshimet hyjnë në fuqi menjëherë pas publikimit në faqe."
msgstr "Η ValorEstate διατηρεί το δικαίωμα τροποποίησης αυτής της πολιτικής ανά πάσα στιγμή. Οι αλλαγές ισχύουν αμέσως μετά τη δημοσίευση."

msgid "Për çdo pyetje rreth kësaj politike privatësie:"
msgstr "Για οποιαδήποτε ερώτηση σχετικά με αυτή την πολιτική απορρήτου:"

msgid "Rruga Myslym Shyri, Nr. 24, Tiranë, Shqipëri"
msgstr "Rruga Myslym Shyri, Αρ. 24, Τίρανα, Αλβανία"

msgid "Kushtet e Përdorimit"
msgstr "Όροι Χρήσης"

msgid "Kushtet dhe rregullat që rregullojnë përdorimin e shërbimeve tona."
msgstr "Οι όροι και κανόνες που διέπουν τη χρήση των υπηρεσιών μας."

msgid "Pranimi i Kushteve"
msgstr "Αποδοχή Όρων"

msgid "Duke përdorur faqen e internetit të ValorEstate, pranoni plotësisht këto kushte përdorimi. Nëse nuk jeni dakord me to, ju lutemi mos përdorni shërbimet tona."
msgstr "Χρησιμοποιώντας τον ιστότοπο της ValorEstate, αποδέχεστε πλήρως αυτούς τους όρους χρήσης. Αν διαφωνείτε, παρακαλούμε μην χρησιμοποιείτε τις υπηρεσίες μας."

msgid "Shërbimet tona"
msgstr "Οι Υπηρεσίες μας"

msgid "ValorEstate ofron shërbime imobiliare duke përfshirë listimin e pronave, ndërmjetësimin në blerje/shitje dhe qira, vlerësimin e pronave dhe konsulencë. Informacioni i paraqitur është vetëm për qëllime informative dhe nuk përbën ofertë juridike të detyrueshme."
msgstr "Η ValorEstate παρέχει κτηματομεσιτικές υπηρεσίες συμπεριλαμβανομένων αγγελιών, μεσιτείας αγοραπωλησίας και ενοικίασης, εκτίμησης και συμβουλευτικής. Οι πληροφορίες παρέχονται μόνο για ενημερωτικούς σκοπούς."

msgid "Detyrimet e Përdoruesit"
msgstr "Υποχρεώσεις Χρήστη"

msgid "Duke përdorur faqen tonë, ju merrni përsipër:"
msgstr "Χρησιμοποιώντας τον ιστότοπό μας, αναλαμβάνετε:"

msgid "Të mos përdorni faqen për qëllime të paligjshme ose të dëmshme."
msgstr "Να μην χρησιμοποιείτε τον ιστότοπο για παράνομους ή επιβλαβείς σκοπούς."

msgid "Të mos ndërhyni në funksionimin normal të faqes."
msgstr "Να μην παρεμβαίνετε στην κανονική λειτουργία του ιστότοπου."

msgid "Të jepni informacione të sakta dhe të vërteta gjatë kontaktit me ne."
msgstr "Να παρέχετε ακριβείς και αληθείς πληροφορίες κατά την επικοινωνία μαζί μας."

msgid "Të respektoni të drejtat e pronësisë intelektuale të ValorEstate."
msgstr "Να σέβεστε τα δικαιώματα πνευματικής ιδιοκτησίας της ValorEstate."

msgid "Pronësia Intelektuale"
msgstr "Πνευματική Ιδιοκτησία"

msgid "Të gjitha materialet e faqes — tekste, imazhe, logo, dizajn — janë pronë e ValorEstate dhe mbrohen nga ligjet e pronësisë intelektuale. Riprodhimi i tyre pa leje të shkruar është i ndaluar."
msgstr "Όλα τα υλικά του ιστότοπου — κείμενα, εικόνες, λογότυπα, σχεδιασμός — ανήκουν στη ValorEstate και προστατεύονται από νόμους πνευματικής ιδιοκτησίας."

msgid "Kufizimi i Përgjegjësisë"
msgstr "Περιορισμός Ευθύνης"

msgid "ValorEstate nuk mban përgjegjësi për dëme direkte ose indirekte që rrjedhin nga përdorimi i faqes ose besimi në informacionin e publikuar. Çdo vendim i marrë bazuar në informacionin e faqes është përgjegjësi e plotë e përdoruesit."
msgstr "Η ValorEstate δεν ευθύνεται για άμεσες ή έμμεσες ζημίες από τη χρήση του ιστότοπου. Κάθε απόφαση που λαμβάνεται βάσει των πληροφοριών του ιστότοπου είναι αποκλειστική ευθύνη του χρήστη."

msgid "Lidhjet me Faqe të Tjera"
msgstr "Σύνδεσμοι προς Άλλους Ιστότοπους"

msgid "Faqja mund të përmbajë lidhje drejt faqeve të palëve të treta. ValorEstate nuk mban përgjegjësi për përmbajtjen apo politikat e privatësisë të këtyre faqeve."
msgstr "Ο ιστότοπος μπορεί να περιέχει συνδέσμους σε ιστότοπους τρίτων. Η ValorEstate δεν ευθύνεται για το περιεχόμενό τους."

msgid "Ndryshimet e Kushteve"
msgstr "Αλλαγές Όρων"

msgid "ValorEstate rezervon të drejtën të ndryshojë këto kushte në çdo kohë. Ndryshimet hyjnë në fuqi menjëherë pas publikimit. Përdorimi i vazhdueshëm i faqes pas ndryshimeve nënkupton pranimin e tyre."
msgstr "Η ValorEstate διατηρεί το δικαίωμα να αλλάξει τους όρους ανά πάσα στιγμή. Οι αλλαγές ισχύουν αμέσως. Η συνέχιση χρήσης συνεπάγεται αποδοχή."

msgid "Ligji i Zbatueshëm"
msgstr "Εφαρμοστέο Δίκαιο"

msgid "Këto kushte rregullohen nga legjislacioni i Republikës së Shqipërisë. Çdo mosmarrëveshje do të zgjidhet nga gjykatat kompetente shqiptare."
msgstr "Οι παρόντες όροι διέπονται από τη νομοθεσία της Δημοκρατίας της Αλβανίας. Κάθε διαφορά θα επιλύεται από τα αρμόδια αλβανικά δικαστήρια."

msgid "Për çdo pyetje rreth kushteve të përdorimit:"
msgstr "Για οποιαδήποτε ερώτηση σχετικά με τους όρους χρήσης:"

msgid "Politika e"
msgstr "Πολιτική"

msgid "Privatësisë"
msgstr "Απορρήτου"

msgid "Kushtet e"
msgstr "Όροι"

msgid "Përdorimit"
msgstr "Χρήσης"
