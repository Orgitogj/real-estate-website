msgstr "Επικοινωνήστε"

msgid "Kontaktoni"
msgstr "μαζί μας"

msgid "Jemi gjithmonë të gatshëm t'ju ndihmojmë të gjeni pronën e duhur. Shkruani ose telefononi — do t'ju përgjigjemi brenda 24 orëve."
msgstr "Είμαστε πάντα έτοιμοι να σας βοηθήσουμε να βρείτε το κατάλληλο ακίνητο. Γράψτε ή τηλεφωνήστε — θα σας απαντήσουμε εντός 24 ωρών."

msgid "Dërgoni Mesazh"
msgstr "Στείλτε Μήνυμα"

msgid "Si Mund t'ju Ndihmojmë?"
msgstr "Πώς Μπορούμε να σας Βοηθήσουμε;"

msgid "Plotësoni formularin dhe një nga agjentët tanë do t'ju kontaktojë sa më shpejt."
msgstr "Συμπληρώστε τη φόρμα και ένας από τους πράκτορές μας θα επικοινωνήσει μαζί σας το συντομότερο."

msgid "Mesazhi u dërgua me sukses!"
msgstr "Το μήνυμα στάλθηκε επιτυχώς!"

msgid "Faleminderit! Do ju kontaktojmë brenda 24 orëve."
msgstr "Ευχαριστούμε! Θα επικοινωνήσουμε μαζί σας εντός 24 ωρών."

msgid "Gabim i serverit!"
msgstr "Σφάλμα διακομιστή!"

msgid "Ndodhi një problem teknik. Provoni përsëri ose na telefononi direkt."
msgstr "Παρουσιάστηκε τεχνικό πρόβλημα. Δοκιμάστε ξανά ή τηλεφωνήστε μας απευθείας."

msgid "Mesazhi u ruajt, por email-i nuk u dërgua."
msgstr "Το μήνυμα αποθηκεύτηκε, αλλά το email δεν στάλθηκε."

msgid "Do ju kontaktojmë manualisht. Për urgjencë, na telefononi direkt."
msgstr "Θα επικοινωνήσουμε μαζί σας χειροκίνητα. Για επείγοντα, τηλεφωνήστε μας απευθείας."

msgid "Ju lutem korrigjoni gabimet:"
msgstr "Παρακαλούμε διορθώστε τα σφάλματα:"

