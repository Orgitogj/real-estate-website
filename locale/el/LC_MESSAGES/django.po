msgid "Rreth Nesh"
msgstr "Σχετικά με Εμάς"

msgid "Kryefaqja"
msgstr "Αρχική"

msgid "Kush Jemi"
msgstr "Ποιοι Είμαστε"

msgid "Ne"
msgstr "Εμείς"

msgid "15 vjet eksperiencë, mbi 800 klientë të kënaqur dhe pasion\ntë palëkundur për pronësinë e drejtë."
msgstr "15 χρόνια εμπειρίας, πάνω από 800 ικανοποιημένοι πελάτες και\nακλόνητο πάθος για τη δίκαιη ιδιοκτησία."

msgid "Zyra ValorEstate"
msgstr "Γραφείο ValorEstate"

msgid "Historia Jonë"
msgstr "Η Ιστορία μας"

msgid "Ndërtuar mbi"
msgstr "Χτισμένο πάνω σε"

msgid "Besim & Rezultate"
msgstr "Εμπιστοσύνη & Αποτελέσματα"

msgid "ValorEstate u themelua në vitin 2009 me një vizion të qartë: të transformojë tregun imobiliar shqiptar duke ofruar shërbime transparente, profesionale dhe të orientuara drejt klientit."
msgstr "Η ValorEstate ιδρύθηκε το 2009 με ένα σαφές όραμα: να μεταμορφώσει την αλβανική αγορά ακινήτων προσφέροντας διαφανείς, επαγγελματικές και πελατοκεντρικές υπηρεσίες."

msgid "Sot jemi agjencia kryesore imobiliare në vend, me ekip të specializuar agjentësh, mbi 120 prona aktive dhe prezencë në të gjithë Shqipërinë — nga Tirana deri në Sarandë."
msgstr "Σήμερα είμαστε το κορυφαίο κτηματομεσιτικό γραφείο στη χώρα, με εξειδικευμένη ομάδα πρακτόρων, πάνω από 120 ενεργά ακίνητα και παρουσία σε όλη την Αλβανία — από τα Τίρανα έως τη Σαράντα."

msgid "Transparencë e Plotë"
msgstr "Πλήρης Διαφάνεια"

msgid "Asnjë kosto të fshehur, asnjë surprizë — vetëm çmime të drejta."
msgstr "Κανένα κρυφό κόστος, καμία έκπληξη — μόνο δίκαιες τιμές."

msgid "Ekip i Licensuar"
msgstr "Αδειοδοτημένη Ομάδα"

msgid "Çdo agjent i certifikuar dhe i trajnuar sipas standardeve ndërkombëtare."
msgstr "Κάθε πράκτορας πιστοποιημένος και εκπαιδευμένος σύμφωνα με διεθνή πρότυπα."

msgid "Mbulim Kombëtar"
msgstr "Εθνική Κάλυψη"

msgid "Prona në Tiranë, Durrës, Vlorë, Shkodër, Sarandë dhe më gjerë."
msgstr "Ακίνητα στα Τίρανα, Δυρράχιο, Αυλώνα, Σκόδρα, Σαράντα και αλλού."

msgid "Misioni Ynë"
msgstr "Η Αποστολή μας"

msgid "Të ofrojmë shërbimin më të mirë imobiliar në Shqipëri duke ndërtuar marrëdhënie afatgjata me klientët, bazuar në besim, profesionalizëm dhe njohuri të thellë të tregut."
msgstr "Να παρέχουμε την καλύτερη κτηματομεσιτική υπηρεσία στην Αλβανία χτίζοντας μακροχρόνιες σχέσεις με τους πελάτες, βασισμένες σε εμπιστοσύνη, επαγγελματισμό και βαθιά γνώση της αγοράς."

msgid "Vizioni Ynë"
msgstr "Το Όραμά μας"

msgid "Të bëhemi platforma imobiliare më e besueshme dhe inovative në rajonin e Ballkanit, duke lidhur klientët me pronën e ëndrrave të tyre nëpërmjet teknologjisë dhe ekspertizës njerëzore."
msgstr "Να γίνουμε η πιο αξιόπιστη και καινοτόμος κτηματομεσιτική πλατφόρμα στη Βαλκανική περιοχή, συνδέοντας τους πελάτες με το ακίνητο των ονείρων τους μέσω τεχνολογίας και ανθρώπινης εξειδίκευσης."

msgid "Vlerat Tona"
msgstr "Οι Αξίες μας"

msgid "Integritet, inovacion dhe partneritet — tre shtyllat mbi të cilat ndërtojmë çdo marrëdhënie me klientët, partnerët dhe komunitetin ku operojmë çdo ditë."
msgstr "Ακεραιότητα, καινοτομία και εταιρικότητα — οι τρεις πυλώνες πάνω στους οποίους χτίζουμε κάθε σχέση με πελάτες, εταίρους και την κοινότητα όπου δραστηριοποιούμαστε καθημερινά."

msgid "Parimet Tona"
msgstr "Οι Αρχές μας"

msgid "Çfarë Na Dallon"
msgstr "Τι μας Ξεχωρίζει"

msgid "Besueshmëri"
msgstr "Αξιοπιστία"

msgid "Çdo premtim i mbajtur, çdo transaksion i dokumentuar saktë."
msgstr "Κάθε υπόσχεση τηρείται, κάθε συναλλαγή τεκμηριώνεται με ακρίβεια."

msgid "Inovacion"
msgstr "Καινοτομία"

msgid "Teknologji moderne, platformë dixhitale dhe vizualizim 3D të pronave."
msgstr "Σύγχρονη τεχνολογία, ψηφιακή πλατφόρμα και τρισδιάστατη απεικόνιση ακινήτων."

msgid "Partneritet"
msgstr "Εταιρικότητα"

msgid "Bashkëpunojmë ngushtë me klientin deri në mbylljen e çdo transaksioni."
msgstr "Συνεργαζόμαστε στενά με τον πελάτη μέχρι την ολοκλήρωση κάθε συναλλαγής."

msgid "Ekselencë"
msgstr "Αριστεία"

msgid "Standard i lartë në çdo detaj — nga prezantimi i pronës deri te kontrata."
msgstr "Υψηλά πρότυπα σε κάθε λεπτομέρεια — από την παρουσίαση του ακινήτου έως το συμβόλαιο."

msgid "Qëndrueshmëri"
msgstr "Βιωσιμότητα"

msgid "Promovim të pronave efiçente dhe ndërtimeve të gjelbra e të qëndrueshme."
msgstr "Προώθηση ενεργειακά αποδοτικών ακινήτων και πράσινων βιώσιμων κατασκευών."

msgid "Prona Aktive"
msgstr "Ενεργά Ακίνητα"

msgid "Klientë të Kënaqur"
msgstr "Ικανοποιημένοι Πελάτες"

msgid "Agjentë Profesionistë"
msgstr "Επαγγελματίες Πράκτορες"

msgid "Vjet"
msgstr "Χρόνια"

msgid "Eksperiencë në Treg"
msgstr "Εμπειρία στην Αγορά"

msgid "Rrugëtimi Ynë"
msgstr "Η Πορεία μας"

msgid "Historia e ValorEstate"
msgstr "Ιστορία της ValorEstate"

msgid "Themelimi"
msgstr "Ίδρυση"

msgid "ValorEstate hap dyert e para në Tiranë me 3 agjentë dhe vizionin e qartë për të ndryshuar tregun imobiliar shqiptar."
msgstr "Η ValorEstate ανοίγει τις πρώτες της πόρτες στα Τίρανα με 3 πράκτορες και σαφές όραμα για την αλλαγή της αλβανικής αγοράς ακινήτων."

msgid "Zgjerimi Kombëtar"
msgstr "Εθνική Επέκταση"

msgid "Hapim zyra në Durrës dhe Vlorë, duke mbuluar tre qytetet kryesore të Shqipërisë dhe duke rritur ekipin në 20 agjentë."
msgstr "Ανοίγουμε γραφεία στο Δυρράχιο και την Αυλώνα, καλύπτοντας τις τρεις κύριες πόλεις της Αλβανίας και αυξάνοντας την ομάδα σε 20 πράκτορες."

msgid "Platforma Dixhitale"
msgstr "Ψηφιακή Πλατφόρμα"

msgid "Lançojmë platformën tonë online me listim të pronave, kërkim të avancuar dhe vizualizim 3D — e para e tillë në Shqipëri."
msgstr "Λανσάρουμε την online πλατφόρμα μας με καταχωρίσεις ακινήτων, προηγμένη αναζήτηση και τρισδιάστατη απεικόνιση — η πρώτη του είδους στην Αλβανία."

msgid "Çmimi i Industrisë"
msgstr "Βραβείο Κλάδου"

msgid "Fitojmë çmimin \"Best Real Estate Agency Albania\" nga Albanian Real Estate Association, njohje e punës sonë 12-vjeçare."
msgstr "Κερδίζουμε το βραβείο \"Best Real Estate Agency Albania\" από την Albanian Real Estate Association, αναγνώριση της 12χρονης δουλειάς μας."

msgid "Sot & Tutje"
msgstr "Σήμερα & Πέρα"

msgid "Mbi 120 prona aktive, 45+ agjentë dhe ekspansion i ri në Sarandë e Shkodër. Vazhdojmë të rritemi me pasion dhe profesionalizëm."
msgstr "Πάνω από 120 ενεργά ακίνητα, 45+ πράκτορες και νέα επέκταση στη Σαράντα και τη Σκόδρα. Συνεχίζουμε να αναπτυσσόμαστε με πάθος και επαγγελματισμό."

msgid "Gati të Bashkëpunojmë?"
msgstr "Έτοιμοι να Συνεργαστούμε;"

msgid "Na kontaktoni sot dhe ekipi ynë do t'ju ndihmojë të gjeni pronën e duhur."
msgstr "Επικοινωνήστε μαζί μας σήμερα και η ομάδα μας θα σας βοηθήσει να βρείτε το κατάλληλο ακίνητο."


msgid "Shfleto Pronat"
msgstr "Αναζήτηση Ακινήτων"


